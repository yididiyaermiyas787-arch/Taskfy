  <div class="ni" id="ni-dn" onclick="goTasks('completed',this);closeSB()"><span class="nico">✅</span>Completed<span class="nbadge" id="b-dn">0</span></div>
  <div class="ni" id="ni-pn" onclick="goTasks('pinned',this);closeSB()"><span class="nico">📌</span>Pinned<span class="nbadge" id="b-pn">0</span></div>
  <div class="ni" id="ni-ns" onclick="goTasks('unscheduled',this);closeSB()"><span class="nico">🗓️</span>Unscheduled<span class="nbadge" id="b-ns">0</span></div>
