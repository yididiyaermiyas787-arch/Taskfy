  <div class="views">

    <!-- TASKS -->
    <div class="view active" id="view-tasks">
      <div class="stats">
        <div class="sc"><div class="sico sib">📋</div><div><div class="snum" id="sn-all">0</div><div class="slbl">All Tasks</div></div></div>
        <div class="sc"><div class="sico sio">⏰</div><div><div class="snum" id="sn-td">0</div><div class="slbl">Today</div></div></div>
        <div class="sc"><div class="sico sig">✅</div><div><div class="snum" id="sn-dn">0</div><div class="slbl">Completed</div></div></div>
