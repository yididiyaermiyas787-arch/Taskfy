          <h3>🎨 Appearance</h3>
          <div class="srow"><div class="sinf"><strong>Dark Mode</strong></div><div class="sctl"><label class="tog"><input type="checkbox" id="s-dark" onchange="applyDark(this.checked)"><span class="ttrack"></span></label></div></div>
          <div class="srow"><div class="sinf"><strong>Accent Color</strong></div><div class="sctl"><div class="accrow">
