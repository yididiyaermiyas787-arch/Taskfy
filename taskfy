  .calbody{flex-direction:column}
  .calside{width:100%}
  .ccell{min-height:50px}
  .cdot{display:none}
  .tact{opacity:1}
  .sbox,.sort-btn{display:none}
}
@media(max-width:480px){
  .mrow{grid-template-columns:1fr}
