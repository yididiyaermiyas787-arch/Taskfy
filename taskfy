          <div class="srow" style="border-bottom:none"><div class="sinf"><strong>Sidebar Width</strong></div><div class="sctl"><select id="s-sw" onchange="pickSW(this.value)">
            <option value="210px">Compact</option><option value="252px" selected>Default</option><option value="285px">Wide</option>
