        <button class="abt" onclick="openTM(${t.id})" style="opacity:1">✏️</button>
        <button class="abt del" onclick="askDel(${t.id})" style="opacity:1">🗑</button>
      </div>
    </div>`;}).join('');
  h+=`<button class="cal-add" onclick="openTM(undefined,'${ds}')">＋ Add task for this day</button>`;
  side.innerHTML=h;
}

