  const ac=document.getElementById('acc-c');if(ac)ac.value=c;
}

function pickFS(sz,el){document.querySelectorAll('.fsb').forEach(b=>b.classList.remove('pick'));el.classList.add('pick');cfg.fs=sz;document.documentElement.style.setProperty('--fs',sz);save();}
function pickSW(w){cfg.sw=w;document.documentElement.style.setProperty('--sw',w);save();}

function expD(){
  const blob=new Blob([JSON.stringify({tasks,projects,cfg},null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`taskify-${today()}.json`;a.click();
  toast('Exported ✓','ok');
}

function impD(inp){
  const f=inp.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=e=>{try{
    const d=JSON.parse(e.target.result);
    if(d.tasks){tasks=d.tasks;nid=Math.max(...tasks.map(t=>t.id||0),0)+1;}
    if(d.projects)projects=d.projects;
    if(d.cfg)Object.assign(cfg,d.cfg);
    applyDark(cfg.dark);applyAcc(cfg.accent);
    if(cfg.fs)document.documentElement.style.setProperty('--fs',cfg.fs);
    if(cfg.sw)document.documentElement.style.setProperty('--sw',cfg.sw);
    filt='all';curV='tasks';
    showView('tasks');setTitle('All Tasks');showTopbar(true);
    actNav(null,'ni-all');
    renderT();syncSet();toast('Imported ✓','ok');
  }catch(err){console.error(err);toast('Invalid JSON file','err');}};
  r.readAsText(f);inp.value='';
}

function doReset(){
  confirm2('Reset all data?','All tasks and custom projects will be deleted.',()=>{
    tasks=[];
    projects=[
      {id:'p1',name:'Work',color:'#5B3FE4'},
      {id:'p2',name:'Personal',color:'#22C55E'},
      {id:'p3',name:'Shopping',color:'#F97316'},
      {id:'p4',name:'Health',color:'#EC4899'}
    ];
    cfg.total=0; cfg.dproj='p1'; nid=1; calSel=today();
    filt='all'; curV='tasks';
    goTasks('all',document.getElementById('ni-all'));
    syncDprojSel(); S('s-tot',0);
    save();toast('All data cleared','info');
  });
}

// PERSISTENCE
function save(){try{localStorage.setItem('taskify',JSON.stringify({tasks,projects,cfg,nid}));}catch(e){}}
function load(){try{const d=JSON.parse(localStorage.getItem('taskify')||'{}');
  if(d.tasks)tasks=d.tasks;
  if(d.projects)projects=d.projects;
  if(d.cfg)Object.assign(cfg,d.cfg);
  if(d.nid)nid=d.nid;
}catch(e){}}

// MODALS
function openM(id){document.getElementById(id).classList.add('open');}
function closeM(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.mbg').forEach(bg=>bg.addEventListener('click',e=>{if(e.target===bg)bg.classList.remove('open');}));
document.addEventListener('keydown',e=>{
  if(e.key==='Escape')document.querySelectorAll('.mbg.open').forEach(m=>m.classList.remove('open'));
  if(e.key==='n'&&!e.ctrlKey&&!e.metaKey&&document.activeElement.tagName!=='INPUT'&&document.activeElement.tagName!=='TEXTAREA'&&document.activeElement.tagName!=='SELECT'){
    if(curV==='tasks'){const qa=document.getElementById('qa');if(qa){e.preventDefault();qa.focus();}}
    else openTM();
  }
});
function confirm2(title,msg,cb){document.getElementById('c-ttl').textContent=title;document.getElementById('c-msg').textContent=msg;document.getElementById('c-ok').onclick=()=>{closeM('m-con');cb();};openM('m-con');}
function shake(id){const el=document.getElementById(id);if(!el)return;el.style.animation='none';el.getBoundingClientRect();el.style.animation='shake .3s ease';}

// TOAST
let toastT;
function toast(msg,type='info'){
  const el=document.getElementById('toast');el.className=`toast ${type}`;
  document.getElementById('ti').textContent={ok:'✓',err:'✕',info:'ℹ'}[type]||'ℹ';
  document.getElementById('tmsg').textContent=msg;el.classList.add('show');
  clearTimeout(toastT);toastT=setTimeout(()=>el.classList.remove('show'),2800);
}

// SOUND
function playBeep(){try{const c=new(window.AudioContext||window.webkitAudioContext)(),o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.frequency.value=880;o.type='sine';g.gain.setValueAtTime(0,c.currentTime);g.gain.linearRampToValueAtTime(.25,c.currentTime+.01);g.gain.exponentialRampToValueAtTime(.001,c.currentTime+.25);o.start(c.currentTime);o.stop(c.currentTime+.25);}catch(e){}}

// UTILS
function X(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function fade(h){const r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),b=parseInt(h.slice(5,7),16);return`rgba(${r},${g},${b},.13)`;}
function S(id,v){const el=document.getElementById(id);if(el)el.textContent=v;}

// INIT
(function init(){
  load();
  applyDark(cfg.dark);
  applyAcc(cfg.accent);
  if(cfg.fs)document.documentElement.style.setProperty('--fs',cfg.fs);
  if(cfg.sw)document.documentElement.style.setProperty('--sw',cfg.sw);
  // sync avatar
  const ch=(cfg.name||'A')[0].toUpperCase();
  ['ava','ava-mob','ava-big'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=ch;});
  const n=new Date();
  calY=n.getFullYear(); calM=n.getMonth(); calSel=today();
  renderT();
  syncDprojSel();
  showTopbar(true);
})();
</script>
</body>
