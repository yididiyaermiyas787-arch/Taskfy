// CALENDAR
function initCal(){const n=new Date();if(calY===undefined){calY=n.getFullYear();calM=n.getMonth();}calSel=calSel||today();}
function calPrev(){calM--;if(calM<0){calM=11;calY--;}renderCal();}
function calNext(){calM++;if(calM>11){calM=0;calY++;}renderCal();}
function calToday(){const n=new Date();calY=n.getFullYear();calM=n.getMonth();calSel=today();renderCal();}

function renderCal(){
  const MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('cal-ttl').textContent=`${MONTHS[calM]} ${calY}`;
  const grid=document.getElementById('cal-grid');
  const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  let h=DAYS.map(d=>`<div class="cdh">${d}</div>`).join('');
  const first=new Date(calY,calM,1).getDay();
  const dim=new Date(calY,calM+1,0).getDate();
  const dip=new Date(calY,calM,0).getDate();
  const td=today();
  for(let i=first-1;i>=0;i--){
    const ds=iso(new Date(calY,calM-1,dip-i));
    h+=ccell(ds,dip-i,true,ds===td,ds===calSel,tasks.filter(t=>t.due===ds));
  }
  for(let i=1;i<=dim;i++){
    const ds=`${calY}-${String(calM+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
    h+=ccell(ds,i,false,ds===td,ds===calSel,tasks.filter(t=>t.due===ds));
  }
  const tot=Math.ceil((first+dim)/7)*7;
  for(let i=first+dim,n=1;i<tot;i++,n++){
    const ds=iso(new Date(calY,calM+1,n));
    h+=ccell(ds,n,true,ds===td,ds===calSel,tasks.filter(t=>t.due===ds));
  }
  grid.innerHTML=h;
  renderCalSide(calSel||td);
}

function ccell(ds,day,om,isTd,isSel,dt){
  let cls='ccell';if(om)cls+=' om';if(isTd)cls+=' today';if(isSel)cls+=' sel';
  const dots=dt.slice(0,2).map(t=>{const p=projects.find(x=>x.id===t.projId),c=p?p.color:'#999';
    return`<div class="cdot" style="background:${fade(c)};color:${c};${t.done?'opacity:.5':''}" onclick="event.stopPropagation();toggleDone(${t.id})" title="${X(t.name)}">${t.done?'✓ ':''}${X(t.name)}</div>`;}).join('');
  const more=dt.length>2?`<div style="font-size:9px;color:var(--ts)">+${dt.length-2} more</div>`:'';
  return`<div class="${cls}" onclick="calClick('${ds}')"><div class="cdn">${day}</div>${dots}${more}</div>`;
}

function calClick(ds){calSel=ds;renderCal();}

function renderCalSide(ds){
  const side=document.getElementById('cal-side');
  const lbl=new Date(ds+'T00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
  const dt=tasks.filter(t=>t.due===ds);
  let h=`<div class="csh">Tasks for</div><div class="csd">${lbl}</div>`;
  if(!dt.length)h+=`<div class="cempty">No tasks this day</div>`;
  else h+=dt.map(t=>{
    const p=projects.find(x=>x.id===t.projId),pc=p?p.color:'#999';
    return`<div class="cti">
      <div class="chk${t.done?' on':''}" onclick="toggleDone(${t.id})">${t.done?'✓':''}</div>
      <div class="cti-body">
        <div class="cti-name${t.done?' done':''}">${X(t.name)}</div>
        <div class="cti-meta">
          <span class="pb ${t.priority}" style="font-size:9.5px;padding:1px 5px">${t.priority}</span>
          ${p?`<span style="font-size:10px;color:${pc}">${X(p.name)}</span>`:''}
        </div>
      </div>
