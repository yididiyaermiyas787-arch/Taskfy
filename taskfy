<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<title>Taskify</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --p:#5B3FE4;--p2:#4530BB;--pl:rgba(91,63,228,.13);
  --bg:#F0F0F7;--card:#fff;--txt:#16162A;--sub:#8587A0;--bdr:#E6E6F0;
  --red:#EF4444;--redbg:#FEF2F2;--org:#F97316;--orgbg:#FFF7ED;--grn:#22C55E;--grnbg:#F0FDF4;
  --sw:252px;--fs:14px;--mob-top:54px;
}
body{--bp:var(--bg);--bc:var(--card);--t:var(--txt);--ts:var(--sub);--b:var(--bdr);--a:var(--p);--a2:var(--p2);--al:var(--pl)}
body.dark{--bp:#0F0F1A;--bc:#1A1A2C;--t:#E2E2F0;--ts:#767896;--b:#2C2C44;--al:rgba(91,63,228,.18)}
html,body{height:100%;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:var(--fs);background:var(--bp);color:var(--t);transition:background .2s,color .2s;overflow:hidden}

/* MOBILE TOP BAR */
.mob-bar{display:none;position:fixed;top:0;left:0;right:0;height:var(--mob-top);background:var(--bc);border-bottom:1px solid var(--b);z-index:300;align-items:center;padding:0 12px;gap:10px}
.mob-bar h1{flex:1;font-size:15px;font-weight:800;color:var(--t)}
.menu-btn{width:34px;height:34px;border:none;background:transparent;color:var(--t);font-size:20px;cursor:pointer;border-radius:7px;display:flex;align-items:center;justify-content:center}
.menu-btn:hover{background:var(--al)}
.mob-fab{display:none;position:fixed;bottom:68px;right:14px;width:50px;height:50px;background:var(--a);color:#fff;border:none;border-radius:50%;font-size:24px;cursor:pointer;box-shadow:0 4px 18px rgba(91,63,228,.4);z-index:200;align-items:center;justify-content:center}
.mob-nav{display:none;position:fixed;bottom:0;left:0;right:0;height:58px;background:var(--bc);border-top:1px solid var(--b);z-index:300;align-items:center;justify-content:space-around}
.mnb{display:flex;flex-direction:column;align-items:center;gap:2px;padding:5px 8px;border:none;background:transparent;color:var(--ts);cursor:pointer;border-radius:7px;font-size:9.5px;font-weight:600;min-width:48px;transition:color .14s}
.mnb.active{color:var(--a)}
.mnb span{font-size:17px;line-height:1}
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:299}
.ov.open{display:block}

/* LAYOUT */
.app{display:flex;height:100%}

/* SIDEBAR */
.sidebar{width:var(--sw);min-width:var(--sw);background:var(--bc);border-right:1px solid var(--b);display:flex;flex-direction:column;padding:18px 12px 14px;overflow-y:auto;transition:background .2s,border-color .2s,transform .22s;flex-shrink:0;z-index:300}
.logo{display:flex;align-items:center;gap:8px;font-size:18px;font-weight:800;color:var(--t);margin-bottom:18px}
.lmark{width:30px;height:30px;background:var(--a);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;flex-shrink:0}
.btn-new{display:flex;align-items:center;justify-content:center;gap:5px;background:var(--a);color:#fff;border:none;border-radius:8px;padding:8px 12px;font-size:12.5px;font-weight:700;cursor:pointer;width:100%;margin-bottom:16px;transition:background .14s}
.btn-new:hover{background:var(--a2)}
.nlbl{font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--ts);margin:10px 4px 5px}
.ni{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--t);transition:background .12s,color .12s;position:relative;user-select:none;white-space:nowrap}
.nico{width:16px;text-align:center;flex-shrink:0;font-size:13px}
.ni:hover{background:var(--al);color:var(--a)}
.ni.active{background:var(--al);color:var(--a);font-weight:700}
.ni.active::before{content:'';position:absolute;left:-12px;top:22%;bottom:22%;width:3px;background:var(--a);border-radius:0 3px 3px 0}
.nbadge{margin-left:auto;background:var(--al);color:var(--a);font-size:10.5px;font-weight:700;padding:1px 5px;border-radius:9px;min-width:18px;text-align:center}
.ni.active .nbadge{background:var(--a);color:#fff}
.pact{margin-left:auto;display:flex;align-items:center;gap:1px;opacity:0;transition:opacity .12s}
.ni:hover .pact{opacity:1}
.ni:hover .nbadge{display:none}
.pdot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.add-proj{display:flex;align-items:center;gap:5px;padding:6px 9px;font-size:12.5px;font-weight:600;color:var(--a);cursor:pointer;border-radius:7px;transition:background .12s}
.add-proj:hover{background:var(--al)}
.sfoot{margin-top:auto;padding-top:11px;border-top:1px solid var(--b)}
.dark-row{display:flex;align-items:center;gap:8px;padding:7px 9px;font-size:13px;color:var(--t)}
.tog{margin-left:auto;position:relative;width:32px;height:18px;flex-shrink:0}
.tog input{display:none}
.ttrack{position:absolute;inset:0;background:#CBD5E1;border-radius:18px;cursor:pointer;transition:background .18s}
.ttrack::after{content:'';position:absolute;left:2px;top:2px;width:14px;height:14px;background:#fff;border-radius:50%;transition:transform .18s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.tog input:checked+.ttrack{background:var(--a)}
.tog input:checked+.ttrack::after{transform:translateX(14px)}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden;background:var(--bp);transition:background .2s}
.topbar{display:flex;align-items:center;gap:8px;padding:14px 22px 0;flex-shrink:0}
.topbar h1{font-size:19px;font-weight:800;flex:1;color:var(--t)}
.sbox{display:flex;align-items:center;gap:6px;background:var(--bc);border:1px solid var(--b);border-radius:8px;padding:6px 10px;width:170px;transition:border-color .14s}
.sbox:focus-within{border-color:var(--a)}
.sbox input{border:none;outline:none;background:transparent;font-size:12.5px;color:var(--t);width:100%}
.sbox input::placeholder{color:var(--ts)}
.sort-btn{display:flex;align-items:center;gap:4px;background:var(--bc);border:1px solid var(--b);border-radius:8px;padding:6px 10px;font-size:12px;cursor:pointer;color:var(--t);white-space:nowrap;transition:border-color .14s}
.sort-btn:hover{border-color:var(--a)}
.ava{width:30px;height:30px;border-radius:50%;background:var(--al);color:var(--a);font-weight:800;font-size:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid var(--a);flex-shrink:0}
.ava:hover{transform:scale(1.08)}

/* VIEWS */
.views{flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0;padding:12px 22px 14px}
.view{display:none;flex-direction:column;gap:12px;flex:1;overflow:hidden;min-height:0}
.view.active{display:flex}

/* STATS */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;flex-shrink:0}
.sc{background:var(--bc);border:1px solid var(--b);border-radius:11px;padding:12px 13px;display:flex;align-items:center;gap:10px}
.sico{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.sib{background:#EEF2FF}.sio{background:#FFF7ED}.sig{background:#F0FDF4}.siv{background:var(--al)}
.snum{font-size:19px;font-weight:800;color:var(--t);line-height:1}
.slbl{font-size:10.5px;color:var(--ts);margin-top:2px}

/* QUICK ADD */
.qabar{display:flex;gap:6px;background:var(--bc);border:1.5px solid var(--b);border-radius:9px;padding:3px 3px 3px 12px;align-items:center;flex-shrink:0;transition:border-color .14s}
.qabar:focus-within{border-color:var(--a)}
.qabar input{flex:1;border:none;outline:none;font-size:13.5px;color:var(--t);background:transparent;min-width:0}
.qabar input::placeholder{color:var(--ts)}
.btn-qa{background:var(--a);color:#fff;border:none;border-radius:7px;padding:7px 14px;font-size:12.5px;font-weight:700;cursor:pointer;transition:background .14s;white-space:nowrap;flex-shrink:0}
.btn-qa:hover{background:var(--a2)}

/* TASK LIST */
.tlist{background:var(--bc);border:1px solid var(--b);border-radius:11px;overflow-y:auto;flex:1}
.trow{display:flex;align-items:center;gap:9px;padding:10px 13px;border-bottom:1px solid var(--b);transition:background .1s;position:relative}
.trow:last-child{border-bottom:none}
.trow:hover{background:var(--al)}
.trow:hover .tact{opacity:1}
.chk{width:18px;height:18px;border:2px solid #C8C8DC;border-radius:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s;font-size:10px;color:#fff}
.chk.on{background:var(--a);border-color:var(--a)}
.tbody{flex:1;min-width:0}
.tname{font-size:13px;font-weight:500;color:var(--t);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tname.done{text-decoration:line-through;color:var(--ts)}
.ttag{display:inline-block;font-size:10px;font-weight:700;padding:1px 6px;border-radius:20px;margin-top:2px}
.tnote{font-size:10.5px;color:var(--ts);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:1px}
.tright{display:flex;align-items:center;gap:6px;flex-shrink:0}
.pb{font-size:10.5px;font-weight:700;padding:2px 7px;border-radius:18px;white-space:nowrap}
.pb.high{color:var(--red);background:var(--redbg)}.pb.medium{color:var(--org);background:var(--orgbg)}.pb.low{color:var(--grn);background:var(--grnbg)}
.duc{font-size:10.5px;color:var(--ts);white-space:nowrap;display:flex;align-items:center;gap:3px}
.duc.od{color:var(--red);font-weight:600}
.tact{display:flex;align-items:center;gap:2px;opacity:0;transition:opacity .12s}
.abt{width:23px;height:23px;border-radius:5px;border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11.5px;color:var(--ts);transition:background .1s}
.abt:hover{background:var(--al);color:var(--a)}
.abt.del:hover{background:var(--redbg);color:var(--red)}
.empty{text-align:center;padding:36px 18px;color:var(--ts)}
.empty .ei{font-size:34px;margin-bottom:9px}
.empty p{font-size:13px}.empty small{font-size:11.5px;display:block;margin-top:3px}

/* CALENDAR */
.calwrap{display:flex;flex-direction:column;gap:10px;flex:1;overflow:hidden}
.calhdr{display:flex;align-items:center;gap:7px;flex-shrink:0}
.calhdr h2{font-size:15px;font-weight:800;flex:1;color:var(--t)}
.calnav{width:28px;height:28px;border:1px solid var(--b);border-radius:6px;background:var(--bc);color:var(--t);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.calnav:hover{border-color:var(--a);color:var(--a)}
.calbody{display:flex;gap:10px;flex:1;overflow:hidden;min-height:0}
.calgrid-wrap{flex:1;overflow-y:auto}
.calgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cdh{text-align:center;font-size:10.5px;font-weight:700;color:var(--ts);padding:3px 0}
.ccell{background:var(--bc);border:1px solid var(--b);border-radius:7px;min-height:76px;padding:5px;cursor:pointer;transition:border-color .12s,background .1s;position:relative;overflow:hidden}
.ccell:hover{border-color:var(--a)}
.ccell.today{border-color:var(--a);border-width:2px}
.ccell.sel{background:var(--al)}
.ccell.om .cdn{color:var(--ts);opacity:.45}
.cdn{font-size:11.5px;font-weight:700;color:var(--t);margin-bottom:3px}
.ccell.today .cdn{color:var(--a)}
.cdot{font-size:9.5px;font-weight:600;padding:1px 4px;border-radius:3px;margin-bottom:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.calside{width:230px;flex-shrink:0;overflow-y:auto;display:flex;flex-direction:column;gap:8px}
.csh{font-size:13px;font-weight:800;color:var(--t)}
.csd{font-size:11px;color:var(--ts);margin-bottom:4px}
.cti{display:flex;align-items:center;gap:7px;padding:8px 9px;background:var(--bc);border:1px solid var(--b);border-radius:8px;margin-bottom:5px}
.cti-body{flex:1;min-width:0}
.cti-name{font-size:12px;font-weight:500;color:var(--t);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cti-name.done{text-decoration:line-through;color:var(--ts)}
.cti-meta{display:flex;gap:5px;align-items:center;margin-top:2px}
.cempty{font-size:12px;color:var(--ts);text-align:center;padding:14px 0}
.cal-add{width:100%;padding:6px;background:var(--al);color:var(--a);border:1px dashed var(--a);border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;margin-top:4px;transition:background .14s;font-family:inherit}
.cal-add:hover{background:var(--a);color:#fff}

/* ANALYTICS */
.anascroll{overflow-y:auto;flex:1;padding-right:2px}
.ptabs{display:flex;gap:3px;background:var(--bp);border:1px solid var(--b);padding:3px;border-radius:9px;width:fit-content;flex-shrink:0}
.ptab{padding:5px 13px;border-radius:7px;border:none;background:transparent;font-size:11.5px;font-weight:600;cursor:pointer;color:var(--ts);transition:all .14s;font-family:inherit}
.ptab.active{background:var(--bc);color:var(--a);box-shadow:0 1px 4px rgba(0,0,0,.1)}
.kgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-bottom:12px}
.kbox{background:var(--bc);border:1px solid var(--b);border-radius:11px;padding:13px 15px}
.kv{font-size:26px;font-weight:900;color:var(--a);line-height:1;letter-spacing:-.5px}
.kl{font-size:10.5px;color:var(--ts);margin-top:4px}
.kd{font-size:10.5px;font-weight:700;margin-top:3px}
.kd.pos{color:var(--grn)}.kd.neg{color:var(--red)}.kd.neu{color:var(--ts)}
.cduo{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:12px}
.cbox{background:var(--bc);border:1px solid var(--b);border-radius:11px;padding:15px 17px;margin-bottom:10px}
.cbox h4{font-size:12px;font-weight:700;color:var(--t);margin-bottom:11px}
.plst{display:flex;flex-direction:column;gap:9px}
.phdr{display:flex;justify-content:space-between;margin-bottom:4px;font-size:11.5px}
.pnm{font-weight:600;color:var(--t)}.pst{color:var(--ts)}
.pbar{height:6px;background:var(--b);border-radius:6px;overflow:hidden}
.pfill{height:100%;border-radius:6px;transition:width .5s ease}
.ilstr{display:flex;flex-direction:column;gap:6px}
.iitm{display:flex;align-items:flex-start;gap:8px;padding:9px 11px;background:var(--bp);border-radius:8px;font-size:12px;color:var(--t);line-height:1.5}
.iico{font-size:14px;flex-shrink:0;margin-top:1px}
.hmrow{display:flex;gap:3px;flex-wrap:wrap;margin-top:4px}
.hmc{width:13px;height:13px;border-radius:3px;background:var(--b);cursor:default;position:relative}
.hmc:hover::after{content:attr(data-tip);position:absolute;bottom:16px;left:50%;transform:translateX(-50%);background:#1A1A2C;color:#fff;font-size:9.5px;padding:2px 6px;border-radius:4px;white-space:nowrap;z-index:20;pointer-events:none}
.hm0{background:var(--b)}.hm1{background:#C4B5FD}.hm2{background:#A78BFA}.hm3{background:#7C3AED}.hm4{background:#4C1D95}
.hmleg{display:flex;align-items:center;gap:4px;font-size:9.5px;color:var(--ts);margin-top:7px}
.hmlc{width:11px;height:11px;border-radius:2px}

/* SETTINGS */
.setscroll{overflow-y:auto;flex:1;padding-right:2px}
.ssec{background:var(--bc);border:1px solid var(--b);border-radius:11px;padding:16px;margin-bottom:10px}
.ssec h3{font-size:11px;font-weight:800;color:var(--ts);text-transform:uppercase;letter-spacing:.08em;margin-bottom:11px;padding-bottom:8px;border-bottom:1px solid var(--b)}
.srow{display:flex;align-items:center;gap:9px;padding:8px 0;border-bottom:1px solid var(--b)}
.srow:last-child{border-bottom:none;padding-bottom:0}
.sinf{flex:1;min-width:0}
.sinf strong{display:block;font-size:13px;font-weight:600;color:var(--t)}
.sinf small{font-size:11px;color:var(--ts);margin-top:1px;display:block}
.sctl{flex-shrink:0}
.sctl input[type=text],.sctl input[type=email],.sctl select{padding:5px 9px;border:1px solid var(--b);border-radius:7px;font-size:12.5px;outline:none;color:var(--t);background:var(--bc);min-width:140px;transition:border-color .14s;font-family:inherit}
.sctl input:focus,.sctl select:focus{border-color:var(--a)}
.sctl select option{background:var(--bc)}
.avabig{width:46px;height:46px;border-radius:50%;background:var(--al);color:var(--a);font-size:19px;font-weight:800;display:flex;align-items:center;justify-content:center;border:2px solid var(--a)}
.accrow{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.asw{width:21px;height:21px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:transform .12s,border-color .12s;flex-shrink:0}
.asw:hover{transform:scale(1.2)}
.asw.pick{border-color:var(--t)!important}
.acc-c{width:21px;height:21px;padding:1px;border:1px solid var(--b);border-radius:50%;cursor:pointer}
.fsgrp{display:flex;gap:4px}
.fsb{padding:4px 10px;border:1px solid var(--b);border-radius:6px;font-size:12px;cursor:pointer;background:var(--bc);color:var(--t);transition:all .14s;font-family:inherit}
.fsb.pick{background:var(--a);color:#fff;border-color:var(--a)}
.bact{background:var(--a);color:#fff;border:none;border-radius:7px;padding:6px 14px;font-size:12.5px;font-weight:700;cursor:pointer;transition:background .14s;font-family:inherit}
.bact:hover{background:var(--a2)}
.bdng{background:var(--redbg);color:var(--red);border:1px solid var(--red);border-radius:7px;padding:6px 14px;font-size:12.5px;font-weight:700;cursor:pointer;font-family:inherit;transition:all .14s}
.bdng:hover{background:var(--red);color:#fff}

/* MODALS */
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.42);z-index:500;align-items:center;justify-content:center;backdrop-filter:blur(2px);padding:14px}
.mbg.open{display:flex}
.modal{background:var(--bc);border-radius:13px;padding:20px;width:410px;max-width:100%;box-shadow:0 18px 55px rgba(0,0,0,.25);animation:mup .17s ease;max-height:90vh;overflow-y:auto;color:var(--t)}
@keyframes mup{from{transform:translateY(14px);opacity:0}to{transform:none;opacity:1}}
.modal h2{font-size:15px;font-weight:800;margin-bottom:14px;color:var(--t)}
.fl{display:block;font-size:10.5px;font-weight:700;color:var(--ts);margin-bottom:3px;margin-top:10px;text-transform:uppercase;letter-spacing:.04em}
.modal input,.modal select,.modal textarea{width:100%;padding:7px 10px;border:1.5px solid var(--b);border-radius:7px;font-size:13px;outline:none;transition:border-color .14s;color:var(--t);background:var(--bc);font-family:inherit}
.modal input:focus,.modal select:focus,.modal textarea:focus{border-color:var(--a)}
.modal textarea{resize:vertical;min-height:54px}
.modal select option{background:var(--bc)}
.mrow{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.mfoot{display:flex;gap:6px;margin-top:14px;justify-content:flex-end}
.bcan{padding:7px 13px;border-radius:7px;border:1px solid var(--b);background:transparent;font-size:12.5px;font-weight:600;cursor:pointer;color:var(--t);font-family:inherit}
.bcan:hover{background:var(--bp)}
.bok{padding:7px 17px;border-radius:7px;border:none;background:var(--a);color:#fff;font-size:12.5px;font-weight:700;cursor:pointer;font-family:inherit;transition:background .14s}
.bok:hover{background:var(--a2)}
.cbox{background:var(--bc);border-radius:11px;padding:20px;width:320px;max-width:100%;box-shadow:0 14px 45px rgba(0,0,0,.22);animation:mup .17s ease}
.cbox h3{font-size:14px;font-weight:800;margin-bottom:6px;color:var(--t)}
.cbox p{font-size:12px;color:var(--ts);line-height:1.5;margin-bottom:14px}
.cfoot{display:flex;gap:6px;justify-content:flex-end}

/* TOAST */
.toast{position:fixed;bottom:18px;right:18px;background:#1A1A2C;color:#fff;padding:8px 13px;border-radius:8px;font-size:12.5px;font-weight:500;opacity:0;transform:translateY(7px);transition:all .24s;z-index:999;pointer-events:none;display:flex;align-items:center;gap:6px;max-width:250px}
.toast.show{opacity:1;transform:none}
.toast.ok .ti{color:var(--grn)}.toast.err .ti{color:var(--red)}.toast.info .ti{color:#60A5FA}
@keyframes shake{0%,100%{transform:none}30%{transform:translateX(-4px)}70%{transform:translateX(4px)}}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--b);border-radius:4px}

/* RESPONSIVE */
@media(max-width:768px){
  .mob-bar{display:flex}
  .mob-fab{display:flex}
  .mob-nav{display:flex}
  html,body{overflow:hidden}
  .app{padding-top:var(--mob-top);padding-bottom:58px}
  .sidebar{position:fixed;top:0;left:0;bottom:0;z-index:300;transform:translateX(-110%);padding-top:calc(var(--mob-top) + 6px)}
  .sidebar.open{transform:none}
  .topbar{display:none}
  .views{padding:8px 10px 8px}
  .stats{grid-template-columns:repeat(2,1fr);gap:7px}
  .kgrid{grid-template-columns:repeat(2,1fr)}
