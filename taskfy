function setPeriod(p,el){per=p;document.querySelectorAll('.ptab').forEach(b=>b.classList.remove('active'));el.classList.add('active');destroyC();renderAna();}
function destroyC(){Object.values(charts).forEach(c=>{try{c.destroy();}catch(e){}});charts={};}

function getBuckets(){
  const t=today();
  if(per==='day')return Array.from({length:14},(_,i)=>addD(t,i-13)).map(d=>({key:d,label:new Date(d+'T00:00').toLocaleDateString('en-US',{weekday:'short',day:'numeric'}),tasks:tasks.filter(x=>x.due===d)}));
  if(per==='week')return Array.from({length:10},(_,i)=>{const s=addD(t,(i-9)*7),e=addD(s,6);return{key:s,label:`W${wkn(s)}`,tasks:tasks.filter(x=>x.due&&x.due>=s&&x.due<=e)};});
  if(per==='month')return Array.from({length:8},(_,i)=>{const d=new Date();d.setDate(1);d.setMonth(d.getMonth()-(7-i));const m=d.getMonth(),y=d.getFullYear();
    return{key:`${y}-${String(m+1).padStart(2,'0')}`,label:d.toLocaleDateString('en-US',{month:'short',year:'2-digit'}),tasks:tasks.filter(x=>{if(!x.due)return false;const dt=new Date(x.due+'T00:00');return dt.getMonth()===m&&dt.getFullYear()===y;})};});
  if(!tasks.length)return[];
  const sorted=[...tasks].filter(x=>x.due).sort((a,b)=>a.due>b.due?1:-1);if(!sorted.length)return[];
  const s=new Date(sorted[0].due+'T00:00');s.setDate(1);const e=new Date(today()+'T00:00');e.setDate(1);
  const bkts=[];
  for(let d=new Date(s);d<=e;d.setMonth(d.getMonth()+1)){const m=d.getMonth(),y=d.getFullYear();
    bkts.push({key:`${y}-${String(m+1).padStart(2,'0')}`,label:new Date(y,m,1).toLocaleDateString('en-US',{month:'short',year:'2-digit'}),
      tasks:tasks.filter(x=>{if(!x.due)return false;const dt=new Date(x.due+'T00:00');return dt.getMonth()===m&&dt.getFullYear()===y;})});}
  return bkts;
}
function wkn(s){const d=new Date(s+'T00:00'),j=new Date(d.getFullYear(),0,1);return Math.ceil(((d-j)/86400000+j.getDay()+1)/7);}

