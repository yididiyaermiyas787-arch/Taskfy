// TASK MODAL
function openTM(id,preDate){
  editId=id!==undefined?id:null;
  const t=editId!==null?tasks.find(x=>x.id===editId):null;
  document.getElementById('mt-ttl').textContent=t?'Edit Task':'Add New Task';
  document.getElementById('m-name').value=t?t.name:'';
  document.getElementById('m-due').value=t?(t.due||''):(preDate||'');
  document.getElementById('m-prio').value=t?t.priority:cfg.dprio;
  document.getElementById('m-notes').value=t?(t.notes||''):'';
  const sel=document.getElementById('m-proj');
  sel.innerHTML=projects.map(p=>`<option value="${p.id}" ${(t?t.projId:cfg.dproj)===p.id?'selected':''}>${X(p.name)}</option>`).join('');
  openM('m-task');
  setTimeout(()=>document.getElementById('m-name').focus(),80);
}

function submitT(){
  const name=document.getElementById('m-name').value.trim();
  if(!name){shake('m-name');toast('Task name is required','err');return;}
  const projId=document.getElementById('m-proj').value;
  const priority=document.getElementById('m-prio').value;
  const due=document.getElementById('m-due').value||null;
  const notes=document.getElementById('m-notes').value.trim();
  if(editId!==null){
    const t=tasks.find(x=>x.id===editId);
    if(t)Object.assign(t,{name,projId,priority,due,notes});
    toast('Task updated','ok');
  } else {
    tasks.unshift({id:nid++,name,projId,priority,due,notes,done:false,pinned:false,created:today()});
    cfg.total++;toast('Task added!','ok');
  }
  closeM('m-task');save();renderT();
  if(curV==='calendar'){renderCal();renderCalSide(calSel||today());}
}

