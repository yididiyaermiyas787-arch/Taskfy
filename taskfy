<div class="toast" id="toast"><span class="ti" id="ti">✓</span><span id="tmsg"></span></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
'use strict';
// STATE
let tasks=[],projects=[
  {id:'p1',name:'Work',color:'#5B3FE4'},
  {id:'p2',name:'Personal',color:'#22C55E'},
  {id:'p3',name:'Shopping',color:'#F97316'},
  {id:'p4',name:'Health',color:'#EC4899'},
];
let nid=1,editId=null,editPid=null;
let cfg={dark:false,accent:'#5B3FE4',fs:'14px',sw:'252px',dprio:'medium',dproj:'p1',showDone:true,doneBot:true,total:0,name:'Alex',email:'alex@taskify.app'};
let filt='all',srt='priority',per='week',curV='tasks';
let calY,calM,calSel;
let charts={};

// DATE HELPERS
const iso=d=>d.toISOString().split('T')[0];
const today=()=>iso(new Date());
const tom=()=>{const d=new Date();d.setDate(d.getDate()+1);return iso(d)};
const yest=()=>{const d=new Date();d.setDate(d.getDate()-1);return iso(d)};
const addD=(s,n)=>{const d=new Date(s+'T00:00');d.setDate(d.getDate()+n);return iso(d)};
const isTd=d=>d===today();
const isUp=d=>d&&d>today();
const isOD=(d,dn)=>!dn&&d&&d<today();
function friendly(d){
  if(!d)return'';
  if(d===today())return'Today';if(d===tom())return'Tomorrow';if(d===yest())return'Yesterday';
  return new Date(d+'T00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'});
}

// SIDEBAR MOBILE
function toggleSB(){document.getElementById('sb').classList.toggle('open');document.getElementById('ov').classList.toggle('open');}
function closeSB(){document.getElementById('sb').classList.remove('open');document.getElementById('ov').classList.remove('open');}
function setMN(id){document.querySelectorAll('.mnb').forEach(b=>b.classList.remove('active'));const el=document.getElementById(id);if(el)el.classList.add('active');}

// VIEW NAV
function goTasks(f,el){
  filt=f;curV='tasks';
  showV('tasks');
  const lbl={all:'All Tasks',today:'Today',upcoming:'Upcoming',completed:'Completed',pinned:'Pinned',unscheduled:'Unscheduled'};
  setTitle(lbl[f]||f);
  showTopbar(true);
  actNav(el,{all:'ni-all',today:'ni-td',upcoming:'ni-up',completed:'ni-dn',pinned:'ni-pn',unscheduled:'ni-ns'}[f]||f);
  renderT();
}
function goV(v,el){
  curV=v;filt='all';
  showV(v);
  const lbl={calendar:'Calendar',analytics:'Analytics',settings:'Settings'};
  setTitle(lbl[v]||v);
  showTopbar(false);
  actNav(el,{calendar:'ni-cal',analytics:'ni-ana',settings:'ni-set'}[v]);
  if(v==='calendar'){initCal();renderCal();}
  if(v==='analytics'){destroyC();renderAna();}
  if(v==='settings'){syncSet();}
}
function showV(v){document.querySelectorAll('.view').forEach(x=>x.classList.remove('active'));document.getElementById('view-'+v).classList.add('active');}
function setTitle(t){document.getElementById('pg-ttl').textContent=t;document.getElementById('mob-ttl').textContent=t;}
function showTopbar(on){
  const sb=document.querySelector('.sbox'),so=document.querySelector('.sort-btn');
  if(sb)sb.style.display=on?'flex':'none';
  if(so)so.style.display=on?'flex':'none';
}
function actNav(el,fbId){
  document.querySelectorAll('.sidebar .ni').forEach(n=>n.classList.remove('active'));
  if(el&&el.classList&&el.classList.contains('ni')){el.classList.add('active');return;}
  if(fbId){const f=document.getElementById(fbId);if(f)f.classList.add('active');}
}

// RENDER TASKS
function getFiltered(){
  const q=(document.getElementById('srch')?.value||'').trim().toLowerCase();
  let list=tasks.filter(t=>{
    if(!cfg.showDone&&t.done)return false;
    if(q&&!t.name.toLowerCase().includes(q)&&!(t.notes||'').toLowerCase().includes(q))return false;
    if(filt==='all')return true;
    if(filt==='today')return isTd(t.due);
    if(filt==='upcoming')return isUp(t.due);
    if(filt==='completed')return t.done;
    if(filt==='pinned')return t.pinned;
    if(filt==='unscheduled')return!t.due;
    return t.projId===filt;
  });
  const po={high:0,medium:1,low:2};
  list.sort((a,b)=>{
    if(cfg.doneBot&&a.done!==b.done)return a.done?1:-1;
    if(srt==='priority')return po[a.priority]-po[b.priority];
    if(srt==='date')return(a.due||'9999')>(b.due||'9999')?1:-1;
    return a.name.localeCompare(b.name);
  });
  return list;
}

function renderT(){
  updBadges();
  const list=getFiltered();
  const el=document.getElementById('tlist');
  if(!list.length){
    const m={all:'No tasks yet — add one above!',today:'Nothing due today 🎉',upcoming:'No upcoming tasks',completed:'No completed tasks',pinned:'No pinned tasks',unscheduled:'No unscheduled tasks 🎉'};
    el.innerHTML=`<div class="empty"><div class="ei">📭</div><p>${m[filt]||'No tasks in this project'}</p><small>Tap "+ Add New Task" to get started</small></div>`;
    return;
  }
  el.innerHTML=list.map(tRow).join('');
}

function tRow(t){
  const p=projects.find(x=>x.id===t.projId);
  const pc=p?p.color:'#999',pbg=p?fade(pc):'#f0f0f0';
  const ar=t.priority==='low'?'↓':'↑',pl=t.priority[0].toUpperCase()+t.priority.slice(1);
  const od=isOD(t.due,t.done);
  return`<div class="trow">
    <div class="chk${t.done?' on':''}" onclick="toggleDone(${t.id})">${t.done?'✓':''}</div>
    <div class="tbody">
      <div class="tname${t.done?' done':''}">${X(t.name)}</div>
      ${p?`<span class="ttag" style="color:${pc};background:${pbg}">${X(p.name)}</span>`:''}
      ${t.notes?`<div class="tnote">${X(t.notes)}</div>`:''}
    </div>
    <div class="tright">
      <span class="pb ${t.priority}">${ar} ${pl}</span>
      ${t.due?`<span class="duc${od?' od':''}">📅 ${friendly(t.due)}</span>`:''}
      ${t.pinned?'<span style="font-size:11px;margin-right:2px">📌</span>':''}
      <div class="tact">
        <button class="abt" onclick="openTM(${t.id})" title="Edit">✏️</button>
        <button class="abt" onclick="togPin(${t.id})" title="Pin">${t.pinned?'🗂':'📌'}</button>
        <button class="abt del" onclick="askDel(${t.id})" title="Delete">🗑</button>
      </div>
    </div>
  </div>`;
}

function updBadges(){
  const td=tasks.filter(t=>isTd(t.due)).length,up=tasks.filter(t=>isUp(t.due)).length,dn=tasks.filter(t=>t.done).length,pn=tasks.filter(t=>t.pinned).length,ns=tasks.filter(t=>!t.due).length;
  S('b-all',tasks.length);S('b-td',td);S('b-up',up);S('b-dn',dn);S('b-pn',pn);S('b-ns',ns);
  S('sn-all',tasks.length);S('sn-td',td);S('sn-dn',dn);S('sn-up',up);
  renderProjNav();
}

function deleteP(pid){
  const p=projects.find(x=>x.id===pid);if(!p)return;
  const cnt=tasks.filter(t=>t.projId===pid).length;
  const msg=cnt>0?`"${p.name}" has ${cnt} task${cnt>1?'s':''}. They will become unassigned.`:`Delete project "${p.name}"?`;
  confirm2('Delete Project?',msg,()=>{
    tasks.forEach(t=>{if(t.projId===pid)t.projId=null;});
    projects=projects.filter(x=>x.id!==pid);
    if(cfg.dproj===pid)cfg.dproj=projects[0]?.id||null;
    if(filt===pid){filt='all';setTitle('All Tasks');actNav(null,'ni-all');}
    save();renderT();syncDprojSel();toast('Project deleted','info');
  });
}

function renderProjNav(){
  document.getElementById('proj-nav').innerHTML=projects.map(p=>{
