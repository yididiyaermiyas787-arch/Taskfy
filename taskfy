// TASK ACTIONS
function quickAdd(){
  const inp=document.getElementById('qa');
  const name=inp.value.trim();
  if(!name){inp.focus();toast('Please enter a task name','err');return;}
  const p=projects.find(x=>x.id===cfg.dproj)||projects[0];
  tasks.unshift({id:nid++,name,projId:p?.id||null,priority:cfg.dprio,due:null,done:false,pinned:false,created:today(),notes:''});
  cfg.total++;inp.value='';save();renderT();
  if(curV==='calendar')renderCal();
  toast('Task added!','ok');
}

function toggleDone(id){
  const t=tasks.find(x=>x.id===id);if(!t)return;
  t.done=!t.done;save();renderT();
  if(curV==='calendar')renderCalSide(calSel||today());
  if(t.done){toast('Task completed ✓','ok');if(document.getElementById('s-snd')?.checked)playBeep();}
}

function togPin(id){
  const t=tasks.find(x=>x.id===id);if(!t)return;
  t.pinned=!t.pinned;save();renderT();
  toast(t.pinned?'Task pinned 📌':'Task unpinned','info');
}

function askDel(id){
  const t=tasks.find(x=>x.id===id);if(!t)return;
  confirm2('Delete task?',`"${t.name}" will be removed.`,()=>{
    tasks=tasks.filter(x=>x.id!==id);save();renderT();
    if(curV==='calendar')renderCal();
    toast('Deleted','info');
  });
}

function cycleSort(){
