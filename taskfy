    <div class="dark-row">🌙 Dark<label class="tog"><input type="checkbox" id="dark-tog" onchange="applyDark(this.checked)"><span class="ttrack"></span></label></div>
    <div class="ni" id="ni-set" onclick="goV('settings',this);closeSB()"><span class="nico">⚙️</span>Settings</div>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <h1 id="pg-ttl">All Tasks</h1>
    <div class="sbox"><svg width="12" height="12" fill="none" viewBox="0 0 13 13"><circle cx="5.5" cy="5.5" r="4" stroke="var(--ts)" stroke-width="1.5"/><path d="m9 9 2.5 2.5" stroke="var(--ts)" stroke-width="1.5" stroke-linecap="round"/></svg><input type="text" placeholder="Search…" id="srch" oninput="renderT()"></div>
    <div class="sort-btn" onclick="cycleSort()">Sort: <span id="sort-lbl">Priority</span> ▾</div>
